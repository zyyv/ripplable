{
  "name": "ripplable-workspace",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "dev": "pnpm --filter ripplable dev",
    "build": "pnpm --filter ripplable build",
    "play": "pnpm --filter @ripplable/playground dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "pnpm --filter @ripplable/playground preview",
    "release": "bumpp packages/ui/package.json --git-check --execute \"pnpm build\" && pnpm --filter ripplable publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "bumpp": "catalog:",
    "eslint": "catalog:",
    "netlify-cli": "catalog:",
    "typescript": "catalog:"
  }
}
